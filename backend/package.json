{
    "name": "omnistudy-ai-backend",
    "version": "1.0.0",
    "description": "Backend for OmniStudy AI",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "predev": "kill -9 $(lsof -ti :5001) 2>/dev/null; pkill -9 -f 'ts-node-dev.*server' 2>/dev/null; exit 0",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "seed": "ts-node-dev src/seeder.ts",
        "build": "tsc"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-async-handler": "^1.2.0",
        "google-auth-library": "^10.6.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.4.1",
        "multer": "^2.0.2",
        "openai": "^6.24.0",
        "pdf-parse": "^2.4.5",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.14.2",
        "@types/pdf-parse": "^1.1.5",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    }
}
